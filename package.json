{
  "name": "socrates",
  "version": "0.1.0",
  "description": "Open-source Windows teaching-and-learning copilot — a private overlay that sees your screen, hears your session, and helps on both sides of it: the person explaining and the person trying to understand.",
  "license": "GPL-3.0-or-later",
  "author": "Socrates",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "node build/make-icons.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.socrates.overlay",
    "productName": "Socrates",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "build/tray.png"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Socrates"
    },
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "Socrates transcribes your microphone so it can help you in a live session.",
        "NSCameraUsageDescription": "Socrates does not use the camera.",
        "NSAudioCaptureUsageDescription": "Socrates captures system audio to transcribe the other participant in a session."
      }
    }
  },
  "keywords": [
    "electron",
    "overlay",
    "ai",
    "tutor",
    "teaching",
    "learning",
    "windows"
  ],
  "devDependencies": {
    "electron": "33.2.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/genai": "^0.3.0",
    "lucide-static": "^0.468.0",
    "openai": "^4.73.0"
  }
}
